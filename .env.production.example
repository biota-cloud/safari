# SAFARI Production Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to version control!

# ============================================
# Supabase
# ============================================
# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Anon/public key — safe for client-side, used by Reflex frontend
SUPABASE_KEY=eyJhbGci...your-anon-key

# Service role key — full admin access, server-side only
# Found in Supabase dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE=eyJhbGci...your-service-role-key

# ============================================
# Cloudflare R2 Storage
# ============================================
# S3-compatible endpoint from Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# R2 API token credentials
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key

# Bucket name (must already exist in R2)
R2_BUCKET_NAME=safari-bucket

# ============================================
# Modal (GPU Infrastructure)
# ============================================
# Configure via: modal token set --token-id <id> --token-secret <secret>
# These are usually set by the Modal CLI, not manually in .env
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=

# ============================================
# Application Settings
# ============================================
# Root directory for local GPU workers (default: ~/.safari)
# SAFARI_ROOT=~/.safari

# Set to 'prod' for production deployment
# REFLEX_ENV=prod
